source_env_if_exists .env.deploy.local
watch_file .env.deploy.local

if [[ -n "${DEPLOY_SSH_TARGET:-}" ]]; then
  export SSH_HOST="$DEPLOY_SSH_TARGET"
elif [[ -n "${DEPLOY_SSH_USER:-}" && -n "${DEPLOY_SSH_HOST:-}" ]]; then
  export SSH_HOST="${DEPLOY_SSH_USER}@${DEPLOY_SSH_HOST}"
fi

if [[ -n "${DEPLOY_SSH_PORT:-}" ]]; then
  export SSH_PORT="$DEPLOY_SSH_PORT"
fi

if [[ -n "${DEPLOY_SSH_IDENTITY_FILE:-}" ]]; then
  export SSH_IDENTITY_FILE="$DEPLOY_SSH_IDENTITY_FILE"
fi

if [[ -n "${DEPLOY_SSH_PASSWORD:-}" ]]; then
  export SSHPASS="$DEPLOY_SSH_PASSWORD"
fi
