---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="AvilaLabs is preparing a new mountain-born digital experience." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AvilaLabs | Something is coming</title>
    <script is:inline>
      (() => {
        const params = new URLSearchParams(location.search);
        const lowpoly = params.get("lowpoly");
        const enabled =
          lowpoly !== null &&
          (lowpoly === "" || ["1", "true", "yes"].includes(lowpoly.toLowerCase()));
        const inState = (params.get("state") ?? "")
          .split(",")
          .some((part) => part.trim().toLowerCase() === "lowpoly");
        if (enabled || inState) {
          document.documentElement.classList.add("is-low-poly");
        }

        const root = document.documentElement;
        root.style.setProperty("--sun-travel", "0");
        root.style.setProperty("--moon-travel", "-0.28");
        root.style.setProperty("--sun-opacity", "1");
        root.style.setProperty("--moon-opacity", "0");
        root.style.setProperty("--sky-t", "0");
        root.style.setProperty("--sunset", "0");
        root.style.setProperty("--sunrise", "0");
        root.style.setProperty("--sunrise-travel", "0");
      })();
    </script>
  </head>
  <body>
    <main class="coming-soon" aria-labelledby="page-title">
      <canvas
        id="hero-canvas-back"
        aria-hidden="true"
        aria-label="Low-poly mountain ridge"></canvas>
      <canvas
        id="hero-canvas-front"
        aria-hidden="true"
        aria-label="Low-poly macaws flying across the scene"></canvas>

      <div class="scene-backdrop">
        <div class="night-sky" aria-hidden="true"></div>
        <div class="sunset-haze" aria-hidden="true"></div>
        <div class="sunrise-haze" aria-hidden="true"></div>
        <div class="celestial celestial--sun" aria-hidden="true">
          <span class="sun-disc"></span>
        </div>
        <div class="celestial celestial--moon" aria-hidden="true">
          <span class="moon-disc"></span>
        </div>
        <div class="tree-line" aria-hidden="true"></div>
        <div class="rain-layer" aria-hidden="true"></div>
      </div>

      <div class="scene-2d-only">
        <div class="mountain mountain--back" aria-hidden="true"></div>
        <div class="mountain mountain--front" aria-hidden="true"></div>
      </div>

      <h1 id="page-title" class="wordmark">AvilaLabs</h1>

      <div class="scene-2d-only tiny-macaw tiny-macaw--one" aria-hidden="true">
        <svg viewBox="0 0 180 96">
          <path class="tiny-macaw__wing tiny-macaw__wing--left" d="M87 41 8 12l48 54 43-10Z" />
          <path class="tiny-macaw__wing tiny-macaw__wing--right" d="M94 43 172 9l-43 59-43-12Z" />
          <path class="tiny-macaw__body" d="M64 34h52l18 16-19 17H66L45 50Z" />
          <path class="tiny-macaw__belly" d="M82 53h36l-13 22H82Z" />
          <path class="tiny-macaw__head" d="M116 30h24l16 14-16 13h-25Z" />
          <path class="tiny-macaw__beak" d="M145 39h31l-28 17Z" />
          <circle class="tiny-macaw__eye" cx="136" cy="42" r="3" />
          <path class="tiny-macaw__tail" d="M48 43 9 50l40 12 21-10Z" />
        </svg>
      </div>
      <div class="scene-2d-only tiny-macaw tiny-macaw--two" aria-hidden="true">
        <svg viewBox="0 0 180 96">
          <path class="tiny-macaw__wing tiny-macaw__wing--left" d="M87 41 8 12l48 54 43-10Z" />
          <path class="tiny-macaw__wing tiny-macaw__wing--right" d="M94 43 172 9l-43 59-43-12Z" />
          <path class="tiny-macaw__body" d="M64 34h52l18 16-19 17H66L45 50Z" />
          <path class="tiny-macaw__belly" d="M82 53h36l-13 22H82Z" />
          <path class="tiny-macaw__head" d="M116 30h24l16 14-16 13h-25Z" />
          <path class="tiny-macaw__beak" d="M145 39h31l-28 17Z" />
          <circle class="tiny-macaw__eye" cx="136" cy="42" r="3" />
          <path class="tiny-macaw__tail" d="M48 43 9 50l40 12 21-10Z" />
        </svg>
      </div>
    </main>

    <script src="../scripts/landing.ts"></script>
  </body>
</html>
