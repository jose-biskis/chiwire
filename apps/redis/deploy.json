{
  "image": "chiwire/redis-cache",
  "tag": "latest",
  "container": "redis-cache",
  "build": {
    "context": ".",
    "dockerfile": "Dockerfile"
  },
  "runtime": {
    "containerPort": 6379,
    "visibility": "internal",
    "hostPort": 6379,
    "setPortEnv": false,
    "volumes": [],
    "env": {
      "REDIS_MAXMEMORY": "256mb",
      "REDIS_MAXMEMORY_POLICY": "allkeys-lru"
    }
  }
}
