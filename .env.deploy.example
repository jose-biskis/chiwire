# Copy this file to .env.deploy.local, fill in your values, then run:
#   direnv allow
#
# .env.deploy.local is ignored by git. Do not commit real credentials.

# Either set DEPLOY_SSH_TARGET directly...
# DEPLOY_SSH_TARGET=deploy@example.com

# ...or set user and host separately so .envrc can build SSH_HOST for you.
DEPLOY_SSH_USER=deploy
DEPLOY_SSH_HOST=example.com
DEPLOY_SSH_PORT=22

# Prefer SSH keys when possible:
# DEPLOY_SSH_IDENTITY_FILE=$HOME/.ssh/id_ed25519

# Password auth is supported through sshpass. Install sshpass locally before
# using this, and leave it commented if you use key auth.
# DEPLOY_SSH_PASSWORD=change-me

# App-specific deploy defaults live in each app's deploy.json file.
# For example, apps/hello-http/deploy.json and apps/avila-labs/deploy.json
# control Docker image, container name, build paths, container port, and
# public/internal/domain visibility.

# Reverse proxy defaults used when running scripts/configure-reverse-proxy-ssh.sh
# directly. App deployments with runtime.visibility=domain should usually keep
# these values in the app's deploy.json proxy block instead.
# Set PROXY_DOMAIN to the root domain (host.dev) or a subdomain
# (app.host.dev). For HTTPS, publish the app on localhost and proxy to it:
#   runtime.visibility=domain
PROXY_TYPE=caddy
PROXY_DOMAIN=host.dev
PROXY_UPSTREAM=127.0.0.1:3000
# Required by nginx/certbot unless you accept registration without email.
# PROXY_TLS_EMAIL=admin@host.dev
# PROXY_SKIP_TLS=1
