{
  "name": "chiwire",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript monorepo for personal and business idea projects.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dependency-map": "node scripts/dependency-map.mjs",
    "affected": "node scripts/dependency-map.mjs --affected",
    "deploy:avila": "./scripts/deploy-app.sh apps/avila-labs",
    "dev:avila": "npm run dev --workspace @chiwire/avila-labs",
    "deploy:hello": "./scripts/deploy-app.sh apps/hello-http",
    "deploy:mcps": "./scripts/deploy-app.sh apps/mcps",
    "start:hello": "npm run start --workspace @chiwire/hello-http",
    "start:mcps": "npm run start --workspace @chiwire/mcps",
    "test:deploy-settings": "node --test scripts/deploy-app.test.mjs",
    "typecheck": "npm run typecheck --workspaces",
    "typecheck:watch": "tsc --build --watch"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
